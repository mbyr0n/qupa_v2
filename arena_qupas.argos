<?xml version="1.0"?>
<argos-configuration>
  <framework>
    <experiment length="0" ticks_per_second="10" />
    <system threads="0" />
  </framework>
  <controllers>
    <lua_controller id="lua">
      <actuators>
        <differential_steering implementation="default" />
        <leds implementation="default" medium="leds" />
      </actuators>
      <sensors>
        <qupa_proximity implementation="default" />
        <colored_blob_omnidirectional_camera implementation="rot_z_only" medium="leds" show_rays="true" />
      </sensors>
      <params/>
    </lua_controller>
  </controllers>
<arena size="20, 20, 1" center="0,0,0.5">


    
<!-- LEDs para todas las paredes -->

<!-- LEDs en wall_north (y=6.7, ang=0°) -->
<light id="led_0" position="-2.25,6.7,0.7" color="green" intensity="3.0" medium="leds" />
<light id="led_1" position="-0.75,6.7,0.7" color="blue" intensity="3.0" medium="leds" />
<light id="led_2" position="0.75,6.7,0.7" color="blue" intensity="3.0" medium="leds" />
<light id="led_3" position="2.25,6.7,0.7" color="green" intensity="3.0" medium="leds" />

<!-- LEDs en wall_south (y=-6.7, ang=0°) -->
