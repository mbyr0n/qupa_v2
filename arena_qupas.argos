<distribute>
  <position method="uniform" min="-5,-5,0" max="5,5,0" />
  <orientation method="uniform" min="0,0,0" max="360,0,0" />
  <entity quantity="5" max_trials="100">
    <qupa id="q">
      <controller config="lua" />
    </qupa>
  </entity>
</distribute>

  

</arena>
  <physics_engines>
    <dynamics2d id="dyn2d" />
  </physics_engines>
  <media>
    <led id="leds" index="grid" grid_size="1,1,1" />
    <range_and_bearing id="rab" index="grid" grid_size="1,1,1" />
  </media>
  <visualization>
    <qt-opengl lua_editor="true">
      <camera>
	      <placement idx="0" position="0,0,10" look_at="0,0,0" up="3,0,0" lens_focal_length="20" />			      </camera>
    </qt-opengl>
