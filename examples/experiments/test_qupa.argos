<?xml version="1.0"?>
<argos-configuration>

  <framework>
    <experiment length="0" ticks_per_second="10" />
    <system threads="2" />
  </framework>

  <controllers>
    <lua_controller id="lua">
      <actuators>
        <differential_steering implementation="default" />
        <leds implementation="default" medium="leds" />
      </actuators>
      <sensors>
        <qupa_proximity implementation="default" show_rays="true" />
        
      </sensors>
      <params script="../controllers/lua/obstacle_avoidance.lua" />
    </lua_controller>
  </controllers>

  <arena size="3, 3, 1" center="0,0,0.5">
    <box id="bn" size="0.1, 3, 0.2" movable="false">
      <body position="1.5,0,0"  orientation="0,0,0" />
    </box>
    <box id="bs" size="0.1, 3, 0.2" movable="false">
      <body position="-1.5,0,0" orientation="0,0,0" />
    </box>
    <box id="be" size="3, 0.1, 0.2" movable="false">
      <body position="0,-1.5,0" orientation="0,0,0" />
    </box>
    <box id="bw" size="3, 0.1, 0.2" movable="false">
      <body position="0,1.5,0" orientation="0,0,0" />
    </box>

    <distribute>
      <position method="uniform" min="-1.5,-1.5,0" max="1.5,1.5,0" />
      <orientation method="uniform" min="0,0,0" max="360,0,0" />
      <entity quantity="10" max_trials="100">
        <qupa id="q" tag_medium="tags">
          <controller config="lua" />
        </qupa>
      </entity>
    </distribute>
  </arena>

  <physics_engines>
    <dynamics2d id="dyn2d" />
  </physics_engines>

  <media>
    <!-- Puedes dejar esto; no molesta aunque no uses LEDs -->
    <led id="leds" index="grid" grid_size="1,1,1" />
    <range_and_bearing id="rab" index="grid" grid_size="1,1,1" />
    <tag id="tags" index="grid" grid_size="5,5,5" />
  </media>

  <visualization>
    <qt-opengl lua_editor="true" show_boundary="false">
      
      <camera>
        <placements>
          <placement index="0" position="0.0122872,0.0534732,25.7009" look_at="0.0122872,0.0534732,24.7009" up="-0.00187965,0.999998,0" lens_focal_length="90" />
          <placement index="1" position="-6.01698,3.45411,1.68985" look_at="-5.13495,3.03202,1.48039" up="0.188941,-0.0904165,0.977817" lens_focal_length="30" />
          <placement index="2" position="6.24865,-4.76935,2.71261" look_at="5.52826,-4.16628,2.37006" up="-0.262661,0.219888,0.939499" lens_focal_length="30" />
          <placement index="3" position="-6.25183,-4.76287,2.69551" look_at="-5.59804,-4.13326,2.27582" up="0.302308,0.291125,0.907665" lens_focal_length="30" />
          <placement index="4" position="-6.2675,4.75161,2.71277" look_at="-5.59966,4.11924,2.32022" up="0.285045,-0.269901,0.91973" lens_focal_length="30" />
          <placement index="5" position="  0, 15, 7.5" look_at="0,0,0.25" lens_focal_length="60" />
          <placement index="6" position="-15, 15, 10"  look_at="0,0,0.25" lens_focal_length="90" />
          <placement index="7" position="-15,  0, 7.5" look_at="0,0,0.25" lens_focal_length="60" />
          <placement index="8" position="-15,-15, 10"  look_at="0,0,0.25" lens_focal_length="90" />
        </placements>
      </camera>
    </qt-opengl>
  </visualization>

</argos-configuration>
